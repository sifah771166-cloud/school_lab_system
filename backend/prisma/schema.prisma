generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(uuid())
  email            String             @unique
  password         String
  name             String
  role             String             @default("USER")
  departmentId     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  profilePhoto     String?
  attendances      Attendance[]
  loansApproved    Loan[]             @relation("LoanApprover")
  loans            Loan[]
  notifications    Notification[]
  schedulesCreated Schedule[]         @relation("ScheduleCreator")
  teacher_qr_codes teacher_qr_codes[]
  auditLogs        AuditLog[]
  sessions         Session[]
  department       Department?        @relation(fields: [departmentId], references: [id])

  @@map("users")
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  labs        Lab[]
  users       User[]

  @@map("departments")
}

model Lab {
  id               String             @id @default(uuid())
  name             String
  description      String?
  departmentId     String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  capacity         Int                @default(0)
  attendances      Attendance[]
  items            Item[]
  department       Department         @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  schedules        Schedule[]
  teacher_qr_codes teacher_qr_codes[]

  @@unique([name, departmentId])
  @@map("labs")
}

model Item {
  id          String   @id @default(uuid())
  name        String
  description String?
  quantity    Int      @default(0)
  labId       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    String?  @default("general")
  condition   String?  @default("good")
  lab         Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  loans       Loan[]

  @@map("items")
}

model Schedule {
  id        String   @id @default(uuid())
  labId     String
  title     String?
  date      DateTime
  startTime String
  endTime   String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creator   User     @relation("ScheduleCreator", fields: [createdBy], references: [id])
  lab       Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model Attendance {
  id            String    @id @default(uuid())
  userId        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  classTeaching String?
  date          String?
  endTime       String?
  startTime     String?
  teacherName   String?
  checkInTime   DateTime?
  checkOutTime  DateTime?
  labId         String?
  scheduleId    String?
  lab           Lab?      @relation(fields: [labId], references: [id])
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("attendances")
}

model Loan {
  id              String    @id @default(uuid())
  userId          String
  itemId          String
  quantity        Int
  status          String    @default("pending")
  requestNote     String?
  approvedBy      String?
  approvedAt      DateTime?
  returnedAt      DateTime?
  dueDate         DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  borrowerName    String
  approver        User?     @relation("LoanApprover", fields: [approvedBy], references: [id])
  item            Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("loans")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@index([userId])
  @@map("notifications")
}

model teacher_qr_codes {
  id            String   @id
  teacherId     String
  labId         String
  teacherName   String
  classTeaching String
  date          DateTime
  startTime     String
  endTime       String
  qrCode        String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  labs          Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  users         User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([labId])
  @@index([teacherId])
  @@map("teacher_qr_codes")
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       String
  module       String
  entityId     String?
  entityName   String?
  oldValues    Json?
  newValues    Json?
  ipAddress    String?
  userAgent    String?
  description  String?
  status       String   @default("success")
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  deviceInfo   String?
  lastActivity DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("sessions")
}
