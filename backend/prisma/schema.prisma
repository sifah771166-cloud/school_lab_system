// This is a school laboratory management system
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          String   @default("USER") // USER, ADMIN_JURUSAN, SUPER_ADMIN
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  attendances   Attendance[]
  loans         Loan[]
  loansApproved Loan[] @relation("LoanApprover")
  schedulesCreated Schedule[] @relation("ScheduleCreator")
  notifications Notification[]
  auditLogs     AuditLog[]
  sessions      Session[]

  @@map("users")
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  users     User[]
  labs      Lab[]

  @@map("departments")
}

model Lab {
  id            String   @id @default(uuid())
  name          String
  description   String?
  capacity      Int      @default(0)
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  items         Item[]
  schedules     Schedule[]
  attendances   Attendance[]

  @@unique([name, departmentId])
  @@map("labs")
}

model Item {
  id          String   @id @default(uuid())
  name        String
  description String?
  quantity    Int      @default(0)
  category    String?  @default("general")
  condition   String?  @default("good") // good, fair, poor
  labId       String
  lab         Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  loans       Loan[]

  @@map("items")
}

model Schedule {
  id        String    @id @default(uuid())
  labId     String
  lab       Lab       @relation(fields: [labId], references: [id], onDelete: Cascade)
  title     String?
  date      DateTime  // specific date (ignore time part)
  startTime String    // "HH:mm"
  endTime   String    // "HH:mm"
  createdBy String
  creator   User      @relation("ScheduleCreator", fields: [createdBy], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("schedules")
}

model Attendance {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Check-in/Check-out fields
  labId         String?
  lab           Lab?      @relation(fields: [labId], references: [id], onDelete: SetNull)
  scheduleId    String?
  checkInTime   DateTime?
  checkOutTime  DateTime?
  
  // Kunjungan fields (for visit tracking)
  teacherName   String?   // Nama guru yang mengajar
  classTeaching String?   // Kelas yang diajar (e.g., "XII RPL 1")
  startTime     String?   // Jam mulai (HH:MM format)
  endTime       String?   // Jam selesai (HH:MM format)
  date          String?   // Tanggal kunjungan (YYYY-MM-DD)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("attendances")
}

model Loan {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  quantity    Int
  status      String    @default("pending") // pending, approved, rejected, returned, overdue
  requestNote String?
  approvedBy  String?
  approver    User?     @relation("LoanApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  approvedAt  DateTime?
  returnedAt  DateTime?
  dueDate     DateTime?
  rejectionReason String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("loans")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  category  String   @default("general") // loan, attendance, schedule, system
  read      Boolean  @default(false)
  readAt    DateTime?
  actionUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, etc.
  module      String   // users, labs, items, schedules, attendance, loans, etc.
  entityId    String?  // ID of the affected entity
  entityName  String?  // Name or title of the affected entity
  oldValues   Json?    // Previous values (for UPDATE/DELETE)
  newValues   Json?    // New values (for CREATE/UPDATE)
  ipAddress   String?
  userAgent   String?
  description String?
  status      String   @default("success") // success, failed
  errorMessage String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  deviceInfo   String?
  lastActivity DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  @@index([userId])
  @@index([token])
  @@map("sessions")
}